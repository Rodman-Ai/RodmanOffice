# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me

# --- Google OAuth (Workspace) ---
# Create OAuth client at https://console.cloud.google.com/
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: restrict to a single workspace domain (e.g. acme.com)
GOOGLE_WORKSPACE_DOMAIN=

# --- Anthropic (AI email generation) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
